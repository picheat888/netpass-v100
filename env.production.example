#--------------------------------------------------------------------
# ค่าสำหรับ PRODUCTION — คัดลอกไปเป็น .env บนเครื่อง production แล้วเติมค่าจริง
# (อย่า commit .env จริงเข้า git — ดู .gitignore)
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

app.baseURL = 'https://your-domain.example/'
app.forceGlobalSecureRequests = true

# URL สะอาด — ตัด index.php ออกจากลิงก์ (nginx/Apache ทำ rewrite ให้แล้ว)
app.indexPage = ''

# Session cookie ปลอดภัยเมื่อเสิร์ฟผ่าน HTTPS
cookie.secure = true

# Database — ใส่ค่าจริงบน production และห้ามใช้รหัสเดียวกับ dev
database.default.hostname = localhost
database.default.database = netpass
database.default.username = netpass_app
database.default.password = CHANGE_ME_STRONG_UNIQUE
database.default.DBDriver = MySQLi

# Encryption key — สร้างใหม่ด้วย: php spark key:generate
encryption.key = CHANGE_ME
